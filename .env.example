# Dev lokal: arahkan ke API lokal. Production default: https://api.santap.app
NUXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NUXT_PUBLIC_USE_MOCK_API=true

# ── Laravel Reverb (WebSocket) ────────────────────────────────────────────────
# Wajib diisi agar Echo connect & customer dapat notifikasi real-time open bill
# (event repeat-order-created di private channel open-bill.{billId}).
# Nilai harus cocok dengan REVERB_* di .env API yang sedang dituju.
#
# Dev lokal (API di 127.0.0.1:8000, Reverb `php artisan reverb:start`):
NUXT_PUBLIC_REVERB_APP_KEY=santapreverbkeylocal
NUXT_PUBLIC_REVERB_HOST=127.0.0.1
NUXT_PUBLIC_REVERB_PORT=8080
NUXT_PUBLIC_REVERB_SCHEME=http
#
# Production (Reverb di reverb.santap.app): ganti dengan host/port/key Reverb produksi,
# mis. HOST=reverb.santap.app, PORT=443, SCHEME=https.

